# INSTRUCCIONES: Copia este archivo a .env.local y rellena con tus valores reales
# cp .env.local.example .env.local

# Supabase — servidor/API (opcional si ya usas las de abajo)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui

# OBLIGATORIAS para el navegador (login, cookies Supabase en cliente).
# En Vercel: añade estas dos aunque ya tengas SUPABASE_*; pueden ser los MISMOS valores.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-una-clave-secreta-aqui

# Database Connection
DATABASE_URL=postgresql://postgres:tu-contraseña@db.tu-proyecto.supabase.co:5432/postgres

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Twilio — WhatsApp (ruta /api/notificaciones/enviar y legado /api/notifications/send)
# Dashboard: https://console.twilio.com/ → Account Info (Account SID + Auth Token)
# Sandbox WhatsApp: el remitente debe ser el sender de sandbox, p. ej. whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token_secreto
# Preferido (producción y sandbox). Debe incluir el prefijo de canal whatsapp:
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Opcional (deprecado): si TWILIO_WHATSAPP_FROM no existe, se usa como respaldo.
# TWILIO_WHATSAPP_NUMBER=+14155238886

# Resend — email (misma ruta de notificaciones cuando el canal incluye EMAIL)
# https://resend.com/api-keys — el remitente debe ser un dominio verificado en Resend.
RESEND_API_KEY=re_xxxxxxxx
# Formato: "Nombre visible <correo@tudominio-verificado-en-resend.com>"
RESEND_FROM_EMAIL="Cartera <onboarding@tudominio.com>"

# Cron Jobs
CRON_SECRET=genera-una-clave-secreta-aqui

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000
