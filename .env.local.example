# INSTRUCCIONES: Copia este archivo a .env.local y rellena con tus valores reales
# cp .env.local.example .env.local

# Supabase — servidor/API (opcional si ya usas las de abajo)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key-aqui

# OBLIGATORIAS para el navegador (login, cookies Supabase en cliente).
# En Vercel: añade estas dos aunque ya tengas SUPABASE_*; pueden ser los MISMOS valores.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-una-clave-secreta-aqui

# Database Connection
DATABASE_URL=postgresql://postgres:tu-contraseña@db.tu-proyecto.supabase.co:5432/postgres

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Twilio (Optional)
TWILIO_ACCOUNT_SID=AC_xxxxx
TWILIO_AUTH_TOKEN=tu-token-aqui
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Resend — correos (notificaciones a representantes)
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL="Cartera <onboarding@tudominio.com>"

# Cron Jobs
CRON_SECRET=genera-una-clave-secreta-aqui

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000
